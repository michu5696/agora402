# Agora402 Configuration

# Agent wallet private key (Base Sepolia testnet only for v1)
PRIVATE_KEY=0x...

# Base Sepolia RPC URL
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Deployed Agora402Escrow contract address (set after deployment)
ESCROW_CONTRACT_ADDRESS=0x...

# Treasury address (receives protocol fees)
TREASURY_ADDRESS=0x...

# Arbiter address (resolves disputes)
ARBITER_ADDRESS=0x...

# PostgreSQL connection (for trust scores, v2)
DATABASE_URL=postgresql://localhost:5432/agora402

# Optional: Coinbase CDP API key (for faucet access)
CDP_API_KEY=
CDP_API_SECRET=
